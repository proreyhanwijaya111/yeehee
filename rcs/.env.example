# RCS reads these at runtime. Copy to rcs/.env and fill in your values.
# RCS shares the same Supabase project as the main daemon — credentials boleh
# ambil dari ~/yeehee-daemon/.env yang sudah jalan.

# === Supabase (REQUIRED) ===
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJh...
# Service key recommended — RCS writes to rcs_signals + rcs_models tables
SUPABASE_SERVICE_KEY=eyJh...

# === MT5 broker login (REQUIRED for live data ingestion) ===
# Demo account is fine for training data. Use real account for live signal generation.
MT5_LOGIN=12345678
MT5_PASSWORD=your_mt5_password
MT5_SERVER=ICMarkets-Demo

# === RCS daemon config ===
# Path to config.yaml relative to rcs/ folder
RCS_CONFIG_PATH=config.yaml

# Override broker symbol (optional, fallback to config.yaml mt5.symbol)
# RCS_SYMBOL=XAUUSD.

# Worker ID (auto-generated if empty — uses hostname)
# RCS_WORKER_ID=pcrumah-rcs

# === Optional: Telegram bot (for high-confidence signal push) ===
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
